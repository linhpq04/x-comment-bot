# ============================================================
# COMMENT BOT — Cấu hình môi trường
# Sao chép file này thành .env rồi điền giá trị thực vào
# ============================================================


# ──────────────────────────────────────────────────────────
# TELEGRAM (BẮT BUỘC)
# ──────────────────────────────────────────────────────────

# Token bot Telegram — lấy từ @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Danh sách Telegram user ID được phép điều khiển bot
# Nhiều ID thì ngăn cách bằng dấu phẩy: 123456,789012
# Để trống = tất cả mọi người đều là admin (KHÔNG khuyến khích)
ADMIN_USER_IDS=123456789


# ──────────────────────────────────────────────────────────
# TWITTER — CRAWL (BẮT BUỘC để đọc tweet mới)
# ──────────────────────────────────────────────────────────

# Bearer token để crawl tweet qua Twitter API v2
# Lấy tại: https://developer.twitter.com/en/portal/dashboard
TWITTER_BEARER_TOKEN=


# ──────────────────────────────────────────────────────────
# TWITTER — ĐĂNG COMMENT (BẮT BUỘC để comment)
# ──────────────────────────────────────────────────────────

# Có 2 cách xác thực, dùng 1 trong 2 hoặc cả 2:

# --- Cách 1: Cookie (khuyến khích, ổn định hơn) -----------
# Đặt file twitter-cookies.json vào thư mục gốc của project.
# Xem hướng dẫn lấy cookie bên dưới phần "SETUP COOKIE".
# Bot sẽ tự load cookie khi khởi động.

# --- Cách 2: Username/Password (fallback tự động) ---------
# Bot dùng Playwright đăng nhập nếu không có cookie hoặc cookie hết hạn.
TWITTER_USERNAME=
TWITTER_PASSWORD=
TWITTER_EMAIL=        # Dùng khi Twitter yêu cầu xác minh email

# --- OAuth 1.0a (dùng để like tweet) ----------------------
# Lấy tại: https://developer.twitter.com/en/portal/dashboard
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=


# ──────────────────────────────────────────────────────────
# DEEPSEEK AI (BẮT BUỘC để sinh comment)
# ──────────────────────────────────────────────────────────

# API key DeepSeek — lấy tại: https://platform.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat


# ──────────────────────────────────────────────────────────
# GIỚI HẠN COMMENT
# ──────────────────────────────────────────────────────────

# Số comment tối thiểu / tối đa mỗi GIỜ trong slot hoạt động
COMMENTS_PER_HOUR_MIN=5
COMMENTS_PER_HOUR_MAX=8

# Thời gian chờ giữa 2 comment liên tiếp (milliseconds) — chống ban
# Mặc định: 60000–180000 ms (1–3 phút)
COMMENT_DELAY_MIN_MS=60000
COMMENT_DELAY_MAX_MS=180000

# Thời gian chờ (giây) khi crawl không ra tweet mới, rồi crawl lại
# Mặc định: 300 giây (5 phút)
CRAWL_EMPTY_WAIT=300


# ──────────────────────────────────────────────────────────
# KHUNG GIỜ HOẠT ĐỘNG
# ──────────────────────────────────────────────────────────

# Bỏ comment dòng dưới để bot chạy 24/7, bỏ qua giới hạn giờ
# Mặc định: bot chỉ chạy trong slot en_us_morning (02:00–05:00 GMT+7)
# DISABLE_TIMESLOT=true


# ──────────────────────────────────────────────────────────
# PROXY (Bắt buộc nếu VPS bị Twitter block IP)
# ──────────────────────────────────────────────────────────

# Dùng residential proxy — datacenter IP thường bị Twitter chặn
# Format: http://host:port  hoặc  socks5://host:port
PROXY_SERVER=
PROXY_USERNAME=
PROXY_PASSWORD=


# ──────────────────────────────────────────────────────────
# LOGGING
# ──────────────────────────────────────────────────────────

# Mức log: error | warn | info | debug
LOG_LEVEL=info


# ============================================================
# SETUP COOKIE — twitter-cookies.json
# ============================================================
#
# File twitter-cookies.json cần được đặt ở thư mục gốc project.
# Bot sẽ tự động dùng cookie thay vì đăng nhập mỗi lần.
#
# Cách lấy cookie bằng trình duyệt (Chrome/Edge):
#
#   1. Cài extension "Cookie-Editor" (https://cookie-editor.com)
#   2. Đăng nhập vào x.com bằng tài khoản bot
#   3. Vào x.com, mở Cookie-Editor → bấm "Export" → chọn "JSON"
#   4. Lưu nội dung vào file: twitter-cookies.json (thư mục gốc project)
#
# Hoặc lấy cookie bằng Playwright (nếu có script export-cookies):
#
#   node export-cookies.mjs
#
# Lưu ý:
#   - Cookie thường hết hạn sau vài tuần → cần lấy lại
#   - Bot tự lưu cookie mới sau mỗi lần đăng nhập thành công
#   - Nếu không có file cookie, bot sẽ fallback dùng USERNAME/PASSWORD
# ============================================================
